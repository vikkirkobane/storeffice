# Database
# For local dev with Docker: postgresql://postgres:storeffice123@localhost:5432/storeffice
# For Supabase: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DATABASE_URL=

# better-auth (generate a 64+ char secret: openssl rand -hex 32)
AUTH_SECRET=
AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Supabase (for storage, auth later if we use Supabase auth instead of better-auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@storeffice.com
RESEND_FROM_NAME=Storeffice

# SMS (Twilio) - optional
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_WEBHOOK_SECRET=
PAYSTACK_CALLBACK_URL=http://localhost:3000/api/payments/callback

# Redis (for caching, rate limiting, upstash) - optional
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Postgres (local Docker)
POSTGRES_PASSWORD=storeffice123
