# Vercel Environment Variables (Production)
# Copy these to Vercel Dashboard → Project Settings → Environment Variables

# Database (Supabase)
DATABASE_URL=postgresql://...
AUTH_SECRET=<64-char-random-secret>
AUTH_TRUSTED_ORIGINS=https://your-app.vercel.app

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Storeffice

# Paystack
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_WEBHOOK_SECRET=whsec_...
PAYSTACK_CALLBACK_URL=https://your-app.vercel.app/api/payments/callback

# Optional: SMS, Redis
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
